#########################
# Required settings
#########################

ALLOWED_HOSTS = {{ netbox_allowed_hosts | to_json }}

DATABASES = {
    'default': {
        'ENGINE': 'django.db.backends.postgresql',
        'NAME': '{{ netbox_db_name | default("") }}',
        'USER': '{{ netbox_db_user | default("") }}',
        'PASSWORD': '{{ netbox_db_user_password | default("") }}',
        'HOST': '{{ netbox_sql_db_host | default("localhost") }}',
        'PORT': {{ netbox_sql_db_port | default(5432) }},
        'CONN_MAX_AGE': {{ netbox_db_conn_max_age | default(300) }},
    }
}

REDIS = {
    'tasks': {
        'HOST': '{{ netbox_redis_host | default("localhost") }}',
        'PORT': {{ netbox_redis_port | default(6379) }},
        'USERNAME': '{{ netbox_redis_username | default("") }}',
        'PASSWORD': '{{ netbox_redis_password | default("") }}',
        'DATABASE': {{ netbox_redis_tasks_db | default(0) }},
        'SSL': {{ netbox_redis_ssl | default(False) }},
    },
    'caching': {
        'HOST': '{{ netbox_redis_host | default("localhost") }}',
        'PORT': {{ netbox_redis_port | default(6379) }},
        'USERNAME': '{{ netbox_redis_username | default("") }}',
        'PASSWORD': '{{ netbox_redis_password | default("") }}',
        'DATABASE': {{ netbox_redis_cache_db | default(1) }},
        'SSL': {{ netbox_redis_ssl | default(False) }},
    }
}

SECRET_KEY = '{{ netbox_secret_key | default("changeme") }}'

API_TOKEN_PEPPERS = {
{% for id, pepper in netbox_api_token_peppers.items() %}
    {{ id }}: '{{ pepper }}',
{% endfor %}
}

#########################
# Optional settings
#########################

ADMINS = {{ netbox_admins | to_json }}

AUTH_PASSWORD_VALIDATORS = {{ netbox_auth_password_validators | to_json }}

BASE_PATH = '{{ netbox_base_path | default("") }}'

CORS_ORIGIN_ALLOW_ALL = {{ netbox_cors_allow_all }}
CORS_ORIGIN_WHITELIST = {{ netbox_cors_whitelist | to_json }}
CORS_ORIGIN_REGEX_WHITELIST = {{ netbox_cors_regex_whitelist | to_json }}

CSRF_COOKIE_NAME = '{{ netbox_csrf_cookie_name | default("csrftoken") }}'

DEBUG = {{ netbox_debug }}

DEFAULT_LANGUAGE = '{{ netbox_default_language | default("en-us") }}'

EMAIL = {
    'SERVER': '{{ netbox_email_server | default("") }}',
    'PORT': {{ netbox_email_port | default(25) }},
    'USERNAME': '{{ netbox_email_username | default("") }}',
    'PASSWORD': '{{ netbox_email_password | default("") }}',
    'USE_SSL': {{ netbox_email_use_ssl | default(False) }},
    'USE_TLS': {{ netbox_email_use_tls | default(False) }},
    'TIMEOUT': {{ netbox_email_timeout | default(10) }},
    'FROM_EMAIL': '{{ netbox_email_from | default("") }}',
}

EXEMPT_VIEW_PERMISSIONS = {{ netbox_exempt_view_permissions | to_json }}

INTERNAL_IPS = {{ netbox_internal_ips | to_json }}

LOGGING = {{ netbox_logging | to_json }}

