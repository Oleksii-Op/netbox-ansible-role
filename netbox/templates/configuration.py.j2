LOGIN_FORM_HIDDEN = {{ netbox_login_form_hidden }}
LOGOUT_REDIRECT_URL = '{{ netbox_logout_redirect_url | default("home") }}'

METRICS_ENABLED = {{ netbox_metrics_enabled }}

